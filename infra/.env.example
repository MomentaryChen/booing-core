# Copy to .env in this directory (infra/) before running: .\start.ps1
# docker compose loads .env from the current working directory.

# --- MySQL (required) ---
MYSQL_USER=bookingapp
MYSQL_PASSWORD=bookingcore
MYSQL_ROOT_PASSWORD=bookingcore

# --- Backend DB credentials (required; match MYSQL_USER / MYSQL_PASSWORD for default setup) ---
DB_USERNAME=bookingapp
DB_PASSWORD=bookingcore

# --- Backend JWT (required in prod profile; use a long random secret, 32+ bytes recommended) ---
JWT_SECRET=0123456789abcdef0123456789abcdef

# --- Optional: one-time bootstrap (defaults shown in docker-compose.yml) ---
# BOOTSTRAP_DEFAULT_MERCHANT_ENABLED=false
# BOOTSTRAP_DEFAULT_MERCHANT_NAME=Demo Merchant
# BOOTSTRAP_DEFAULT_MERCHANT_SLUG=demo-merchant
# BOOTSTRAP_DEFAULT_MERCHANT_USER_ENABLED=false
# BOOTSTRAP_DEFAULT_MERCHANT_USER_USERNAME=merchant
# BOOTSTRAP_DEFAULT_MERCHANT_USER_PASSWORD=
# BOOTSTRAP_SYSTEM_ADMIN_ENABLED=false
# BOOTSTRAP_SYSTEM_ADMIN_USERNAME=admin
# BOOTSTRAP_SYSTEM_ADMIN_PASSWORD=
# BOOTSTRAP_DEFAULT_CLIENT_ENABLED=false
# BOOTSTRAP_DEFAULT_CLIENT_USERNAME=client
# BOOTSTRAP_DEFAULT_CLIENT_PASSWORD=
