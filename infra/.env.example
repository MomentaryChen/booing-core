# Copy to .env in this directory (infra/) before running: .\start.ps1
# docker compose loads .env from the current working directory.

# --- Optional: backend Docker build uses host Maven cache (faster when pom changes) ---
# Windows (forward slashes recommended). Ensure this folder is allowed in Docker Desktop file sharing.
# M2_HOST_REPO=C:/Users/YourName/.m2/repository
# Linux/macOS:
# M2_HOST_REPO=/home/you/.m2/repository

# --- MySQL (required) ---
MYSQL_USER=bookingapp
MYSQL_PASSWORD=bookingcore
MYSQL_ROOT_PASSWORD=bookingcore

# --- Backend DB credentials (required; match MYSQL_USER / MYSQL_PASSWORD for default setup) ---
DB_USERNAME=bookingapp
DB_PASSWORD=bookingcore

# --- Backend JWT (required in prod profile; use a long random secret, 32+ bytes recommended) ---
JWT_SECRET=0123456789abcdef0123456789abcdef

# --- Frontend-only compose (optional) ---
# Expose nginx on localhost:${FRONTEND_PORT}
FRONTEND_PORT=18080
# Build-time API base injected into frontend image
FRONTEND_VITE_API_BASE=/api

# --- Internal SYSTEM_ADMIN (auto when no SYSTEM_ADMIN platform user exists yet) ---
INTERNAL_SYSTEM_ADMIN_AUTO_PROVISION=true
INTERNAL_SYSTEM_ADMIN_USERNAME=admin
INTERNAL_SYSTEM_ADMIN_PASSWORD=

# --- Demo merchant/client data ---
# Use manual SQL only: backend/src/main/resources/db/manual/seed_manual_baseline.sql
